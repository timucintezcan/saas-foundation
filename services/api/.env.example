# Runtime
NODE_ENV=development
PORT=4000

# Infra profile (generated defaults)
BACKEND_CLOUD=gcp
FRONTEND_CLOUD=firebase
REGION=europe-west1
PRIMARY_DATA_STORE=relational
USE_OBJECT_STORAGE=true
OBJECT_STORAGE_PROVIDER=gcs

# Database / Queue (local dev defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_foundation
REDIS_URL=redis://localhost:6379

# GCP (backend)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_SERVICE_ACCOUNT_KEY_JSON=
GCS_BUCKET=your-gcs-bucket

# Firebase (frontend integration metadata for API responses if needed)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Security
SIGNED_URL_TTL_SECONDS=86400
